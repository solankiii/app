# Backend API URL — the API client appends /api automatically
# For local dev (use your machine's LAN IP, not localhost):
# EXPO_PUBLIC_BACKEND_URL=http://192.168.x.x:8000

# For production (your Render backend URL):
EXPO_PUBLIC_BACKEND_URL=https://your-backend.onrender.com

# Frontend web URL (your Vercel URL) — used for QR share screen
# EXPO_PUBLIC_WEB_URL=https://your-app.vercel.app
