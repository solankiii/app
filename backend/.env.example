# MongoDB Atlas connection string
MONGO_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?appName=Cluster0
DB_NAME=sales_crm

# JWT secret — use a long random string in production
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-random-secret

# Admin account seeded on first startup
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=change-me-to-strong-password

# CORS allowed origins (comma-separated)
# Use * for local dev, restrict in production
ALLOWED_ORIGINS=https://your-frontend.vercel.app
